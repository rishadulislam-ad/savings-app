rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user document: users/<uid>
    //
    // Reads: only the owner.
    // Writes: only the owner, AND
    //   - only fields from the allowlist (keeps a malicious or compromised
    //     client from polluting the doc with arbitrary keys),
    //   - per-array size caps (keeps a single user from blowing through
    //     their own Firestore quota with junk writes — self-DOS protection).
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
            'transactions',
            'customCategories',
            'customTags',
            'savingsGoals',
            'cards',
            'budgets',
            'trips',
            'currency',
            'settings',
            'tourComplete',
            'updatedAt'
          ])
        && (!('transactions'     in request.resource.data) || request.resource.data.transactions.size()     <= 10000)
        && (!('customCategories' in request.resource.data) || request.resource.data.customCategories.size() <=   500)
        && (!('customTags'       in request.resource.data) || request.resource.data.customTags.size()       <=   500)
        && (!('savingsGoals'     in request.resource.data) || request.resource.data.savingsGoals.size()     <=   100)
        && (!('cards'            in request.resource.data) || request.resource.data.cards.size()            <=    50)
        && (!('trips'            in request.resource.data) || request.resource.data.trips.size()            <=   500)
        && (!('currency'         in request.resource.data) || (request.resource.data.currency is string && request.resource.data.currency.size() <= 16));
    }

    // Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
